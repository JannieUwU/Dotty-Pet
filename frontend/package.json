{
  "name": "dotty-pet",
  "version": "1.0.0",
  "private": true,
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.electron.json && concurrently -n VITE,ELECTRON -c green,cyan --kill-others-on-fail \"vite --port 5173 --strictPort\" \"wait-on http-get://localhost:5173 && electron .\"",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "dist": "npm run build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.40.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "uiohook-napi": "^1.5.5",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.38",
    "rcedit": "^5.0.2",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.dotty.dottypet",
    "productName": "Dotty Pet",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron-dist/**"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!__pycache__",
          "!*.pyc"
        ]
      },
      {
        "from": "../unity-build",
        "to": "unity-build",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  }
}
